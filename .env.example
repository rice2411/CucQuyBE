# ── Firebase Admin (service account) ──
# Lấy từ Firebase Console → Project settings → Service accounts → Generate new private key.
# private_key có ký tự xuống dòng → giữ nguyên \n (code tự replace).
FIREBASE_PROJECT_ID=tiembanhcucquy-75fe1
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tiembanhcucquy-75fe1.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Server ──
PORT=3000
# Danh sách origin FE được phép gọi (phân tách bằng dấu phẩy)
ALLOWED_ORIGINS=http://localhost:3009,https://your-fe.vercel.app
FIREBASE_STORAGE_BUCKET=tiembanhcucquy-75fe1.firebasestorage.app

# ── Tích hợp ngoài (secret — đã chuyển từ FE về BE) ──
SERPAPI_KEY=
VISION_API_KEY=
GEMINI_API_KEY=
ZALO_URL=https://new.abitstore.vn
ZALO_SHOP_CODE=
ZALO_TOKEN=
ZALO_MAIN_GROUP_ID=
SEPAY_MERCHANT_ID=
SEPAY_SECRET_KEY=
